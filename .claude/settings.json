{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/check-file-length.sh",
            "timeout": 10,
            "statusMessage": "Checking file length..."
          }
        ]
      }
    ]
  }
}
