# ============================================================================
# Last Logon — Environment Variables
# ============================================================================
#
# Copy this file to .env and fill in the values:
#
#   cp .env.example .env
#
# Never commit the .env file — it contains secrets.
# ============================================================================


# ─── Database ────────────────────────────────────────────────────────────────
#
# SQLite connection string used by Prisma ORM.
# The path is relative to the prisma/ directory.
#
# Default uses a local SQLite file at data/bbs.sqlite3:
DATABASE_URL="file:../data/bbs.sqlite3"


# ─── AI / Anthropic ─────────────────────────────────────────────────────────
#
# API key for Anthropic's Claude. Required for all AI-driven game features:
#   - Killer persona chat responses
#   - AI-generated puzzle hints (when pre-defined hints are exhausted)
#   - Free-form answer evaluation (AI-validated puzzles)
#   - Conversation summarization (cost-saving context compression)
#   - Async killer messages (background scheduler for inactive players)
#
# The BBS itself runs fine without this — only the Last Logon game's AI
# features need it. The first scripted beats (prologue) use pre-written
# text and require zero API calls.
#
# Get your key at: https://console.anthropic.com/
#
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"

# Override the default Claude model used for AI game responses.
# Useful for testing different models or switching to a cheaper/faster one.
#
# Default (if unset): claude-sonnet-4-20250514
# Examples:
#   claude-sonnet-4-20250514    — balanced cost/quality (default)
#   claude-haiku-4-5-20251001   — faster and cheaper, less nuanced
#   claude-opus-4-6             — highest quality, most expensive
#
# LAST_LOGON_AI_MODEL="claude-sonnet-4-20250514"


# ─── Node.js ────────────────────────────────────────────────────────────────
#
# Standard Node.js environment variable. Controls logging verbosity and
# runtime behavior.
#
# Values: development, production, test
#
# NODE_ENV="development"
